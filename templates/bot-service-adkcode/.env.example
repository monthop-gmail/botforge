# LINE Credentials
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_OA_URL=https://line.me/ti/p/~your-oa

# Google AI (Gemini)
GOOGLE_API_KEY=AIza...

# Model configuration (optional)
# Smart model — used by orchestrator and reviewer
ADKCODE_MODEL_SMART=gemini-2.5-flash
# Fast model — used by coder and tester
ADKCODE_MODEL_FAST=gemini-2.0-flash

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Server (optional)
PORT=3000
PROMPT_TIMEOUT_MS=120000
