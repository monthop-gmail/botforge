#!/usr/bin/env bash
set -euo pipefail

# --- Botforge CLI ---
# Generate new LINE Bot + Workspace projects from templates

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
PROJECTS_DIR="$SCRIPT_DIR/projects"

# Defaults
DEFAULT_GITHUB_ORG="monthop-gmail"
DEFAULT_DOMAIN_SUFFIX="sumana.online"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# --- Helpers ---
print_header() {
    echo ""
    echo -e "${CYAN}${BOLD}Botforge — LINE Bot Project Generator${NC}"
    echo -e "${CYAN}──────────────────────────────────────${NC}"
    echo ""
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

print_error() {
    echo -e "${RED}$1${NC}"
}

print_warn() {
    echo -e "${YELLOW}$1${NC}"
}

DIM='\033[2m'

validate_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-z][a-z0-9-]*$ ]]; then
        print_error "Invalid project name: '$name'"
        echo "  - Use lowercase letters, numbers, and hyphens only"
        echo "  - Must start with a letter"
        echo "  - Example: hr-bot, customer-support, my-project-01"
        return 1
    fi
    if [[ ${#name} -lt 2 || ${#name} -gt 50 ]]; then
        print_error "Project name must be 2-50 characters"
        return 1
    fi
    return 0
}

# --- Command: new ---
cmd_new() {
    local project_name="${1:-}"

    print_header

    # Get project name
    if [[ -z "$project_name" ]]; then
        read -rp "Project name: " project_name
    fi

    # Validate
    if ! validate_name "$project_name"; then
        exit 1
    fi

    # Check if exists
    if [[ -d "$PROJECTS_DIR/$project_name" ]]; then
        print_error "Project '$project_name' already exists at $PROJECTS_DIR/$project_name"
        exit 1
    fi

    echo -e "  Project: ${BOLD}$project_name${NC}"
    echo ""

    # Select engine
    echo "  Engine:"
    echo "    1) opencode    — Multi-model (Claude, GPT, Gemini, DeepSeek, Qwen, Groq)"
    echo "    2) claude-code — Claude only (Agent SDK, simpler, cost control)"
    echo "    3) gocode      — Go + OpenAI-compatible (DeepSeek, GPT, Qwen, Groq, Ollama)"
    echo "    4) adkcode     — Google ADK + Gemini (multi-agent: coder, reviewer, tester)"
    echo "    5) gemini-cli  — Google Gemini CLI (agentic, session support, Google Search)"
    echo "    6) qwen-code  — Alibaba Qwen Code CLI (agentic, free 1K req/day via OAuth)"
    echo "    7) codex       — OpenAI Codex CLI (agentic, ChatGPT login or API key)"
    echo "    8) copilot-cli — GitHub Copilot SDK (Claude/GPT-5/o4-mini, GitHub OAuth)"
    read -rp "  Select [1]: " engine_choice
    engine_choice="${engine_choice:-1}"

    local engine="opencode"
    local bot_template="bot-service-opencode"
    case "$engine_choice" in
        2) engine="claude-code"; bot_template="bot-service-claude-code" ;;
        3) engine="gocode"; bot_template="bot-service-gocode" ;;
        4) engine="adkcode"; bot_template="bot-service-adkcode" ;;
        5) engine="gemini-cli"; bot_template="bot-service-gemini-cli" ;;
        6) engine="qwen-code"; bot_template="bot-service-qwen-code" ;;
        7) engine="codex"; bot_template="bot-service-codex" ;;
        8) engine="copilot-cli"; bot_template="bot-service-copilot-cli" ;;
    esac

    echo ""

    # Get config
    read -rp "  GitHub org/user [$DEFAULT_GITHUB_ORG]: " github_org
    github_org="${github_org:-$DEFAULT_GITHUB_ORG}"
    if [[ ! "$github_org" =~ ^[a-zA-Z0-9._-]+$ ]]; then
        print_error "Invalid GitHub org/user: '$github_org' (alphanumeric, dots, hyphens, underscores only)"
        exit 1
    fi

    read -rp "  Domain suffix [$DEFAULT_DOMAIN_SUFFIX]: " domain_suffix
    domain_suffix="${domain_suffix:-$DEFAULT_DOMAIN_SUFFIX}"
    if [[ ! "$domain_suffix" =~ ^[a-zA-Z0-9.-]+$ ]]; then
        print_error "Invalid domain suffix: '$domain_suffix' (alphanumeric, dots, hyphens only)"
        exit 1
    fi

    local domain="${project_name}.${domain_suffix}"
    local container_prefix="$project_name"

    echo ""
    echo -e "  ${BOLD}Summary:${NC}"
    echo "    Project:    $project_name"
    echo "    Engine:     $engine"
    echo "    GitHub:     $github_org/$project_name"
    echo "    Domain:     $domain"
    echo "    Containers: ${container_prefix}-server, ${container_prefix}-line-bot, ${container_prefix}-tunnel"
    echo ""

    read -rp "  Proceed? [Y/n]: " confirm
    if [[ "${confirm,,}" == "n" ]]; then
        echo "Cancelled."
        exit 0
    fi

    echo ""

    # --- Generate bot-service ---
    local bot_dir="$PROJECTS_DIR/$project_name/bot-service"
    echo -n "  Generating bot-service... "

    # Copy template (based on selected engine)
    mkdir -p "$bot_dir"
    cp -r "$TEMPLATES_DIR/$bot_template/." "$bot_dir/"

    # Replace placeholders in all text files
    find "$bot_dir" -type f \( -name "*.yml" -o -name "*.yaml" -o -name "*.json" -o -name "*.md" -o -name "*.ts" -o -name "*.js" -o -name "*.example" -o -name "*.toml" -o -name ".gitignore" \) -exec \
        sed -i \
            -e "s|{{PROJECT_NAME}}|${project_name}|g" \
            -e "s|{{CONTAINER_PREFIX}}|${container_prefix}|g" \
            -e "s|{{TUNNEL_NAME}}|${project_name}|g" \
            -e "s|{{DOMAIN}}|${domain}|g" \
            -e "s|{{GITHUB_ORG}}|${github_org}|g" \
        {} +

    print_success "done"

    # --- Generate workspace ---
    local ws_dir="$PROJECTS_DIR/$project_name/workspace"
    echo -n "  Generating workspace...   "

    mkdir -p "$ws_dir"
    cp -r "$TEMPLATES_DIR/workspace/." "$ws_dir/"

    find "$ws_dir" -type f \( -name "*.md" -o -name "*.json" -o -name "*.jsonc" \) -exec \
        sed -i \
            -e "s|{{PROJECT_NAME}}|${project_name}|g" \
            -e "s|{{CONTAINER_PREFIX}}|${container_prefix}|g" \
            -e "s|{{DOMAIN}}|${domain}|g" \
            -e "s|{{GITHUB_ORG}}|${github_org}|g" \
        {} +

    print_success "done"

    # --- Git init ---
    echo -n "  Git init (bot-service)... "
    (cd "$bot_dir" && git init -q && git add . && git commit -q -m "feat: initial commit — $project_name (bot-service)") 2>/dev/null
    print_success "done"

    echo -n "  Git init (workspace)...   "
    (cd "$ws_dir" && git init -q && git add . && git commit -q -m "feat: initial commit — $project_name (workspace)") 2>/dev/null
    print_success "done"

    # --- Done ---
    echo ""
    echo -e "${GREEN}${BOLD}Project created successfully!${NC}"
    echo ""
    echo -e "  ${BOLD}bot-service:${NC} $bot_dir"
    echo -e "  ${BOLD}workspace:${NC}   $ws_dir"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo "    1. cd $bot_dir"
    echo "    2. cp .env.example .env    # Set your credentials"
    echo "    3. docker compose up -d --build"
    echo ""
    echo -e "  ${BOLD}Webhook URL:${NC} https://${domain}/webhook"
    echo ""
    echo -e "  ${BOLD}GitHub (optional):${NC}"
    echo "    cd $bot_dir"
    echo "    gh repo create $github_org/$project_name --public --source=. --push"
    echo ""
    echo "    cd $ws_dir"
    echo "    gh repo create $github_org/${project_name}-workspace --private --source=. --push"
    echo ""
}

# --- Command: list ---
cmd_list() {
    print_header

    if [[ ! -d "$PROJECTS_DIR" ]] || [[ -z "$(ls -A "$PROJECTS_DIR" 2>/dev/null)" ]]; then
        echo "  No projects yet. Create one with: ./botforge new <name>"
        echo ""
        return
    fi

    echo -e "  ${BOLD}Projects:${NC}"
    echo ""

    for dir in "$PROJECTS_DIR"/*/; do
        if [[ -d "$dir" ]]; then
            local name
            name=$(basename "$dir")
            local has_bot="no"
            local has_ws="no"
            local engine_type="unknown"
            [[ -d "$dir/bot-service" ]] && has_bot="yes"
            [[ -d "$dir/workspace" ]] && has_ws="yes"
            if [[ -f "$dir/bot-service/server/api.py" ]]; then
                engine_type="adkcode"
            elif [[ -f "$dir/bot-service/server/go.mod" ]]; then
                engine_type="gocode"
            elif [[ -f "$dir/bot-service/opencode.json" ]]; then
                engine_type="opencode"
            elif grep -q "GEMINI_MODEL" "$dir/bot-service/docker-compose.yml" 2>/dev/null; then
                engine_type="gemini-cli"
            elif grep -q "QWEN_MODEL" "$dir/bot-service/docker-compose.yml" 2>/dev/null; then
                engine_type="qwen-code"
            elif grep -q "CODEX_MODEL" "$dir/bot-service/docker-compose.yml" 2>/dev/null; then
                engine_type="codex"
            elif grep -q "COPILOT_MODEL" "$dir/bot-service/docker-compose.yml" 2>/dev/null; then
                engine_type="copilot-cli"
            elif [[ -d "$dir/bot-service/server" ]]; then
                engine_type="claude-code"
            fi
            echo -e "    ${BOLD}$name${NC}  ($engine_type)"
            echo "      bot-service: $has_bot | workspace: $has_ws"
            echo "      path: $dir"
            echo ""
        fi
    done
}

# --- Engine detection (shared with botforge-deploy) ---
detect_engine() {
    local name="$1"
    local dir="$PROJECTS_DIR/$name/bot-service"
    if [[ -f "$dir/server/api.py" ]]; then
        echo "adkcode"
    elif [[ -f "$dir/server/go.mod" ]]; then
        echo "gocode"
    elif [[ -f "$dir/opencode.json" ]]; then
        echo "opencode"
    elif grep -q "GEMINI_MODEL" "$dir/docker-compose.yml" 2>/dev/null; then
        echo "gemini-cli"
    elif grep -q "QWEN_MODEL" "$dir/docker-compose.yml" 2>/dev/null; then
        echo "qwen-code"
    elif grep -q "CODEX_MODEL" "$dir/docker-compose.yml" 2>/dev/null; then
        echo "codex"
    elif grep -q "COPILOT_MODEL" "$dir/docker-compose.yml" 2>/dev/null; then
        echo "copilot-cli"
    elif [[ -d "$dir/server" ]]; then
        echo "claude-code"
    else
        echo "unknown"
    fi
}

# Map engine to template directory name
engine_to_template() {
    local engine="$1"
    case "$engine" in
        opencode)    echo "bot-service-opencode" ;;
        claude-code) echo "bot-service-claude-code" ;;
        gocode)      echo "bot-service-gocode" ;;
        adkcode)     echo "bot-service-adkcode" ;;
        gemini-cli)  echo "bot-service-gemini-cli" ;;
        qwen-code)   echo "bot-service-qwen-code" ;;
        codex)       echo "bot-service-codex" ;;
        copilot-cli) echo "bot-service-copilot-cli" ;;
        *)           echo "" ;;
    esac
}

# Syncable files per engine (infrastructure only, not user code like src/index.ts)
get_sync_files() {
    local engine="$1"
    case "$engine" in
        opencode)
            echo "Dockerfile.opencode docker-compose.yml opencode.json .env.example"
            ;;
        claude-code|gocode|adkcode|gemini-cli|qwen-code|codex|copilot-cli)
            echo "server/Dockerfile docker-compose.yml .env.example"
            ;;
    esac
}

# Full sync files (infrastructure + src/index.ts + CLAUDE.md + server code)
get_full_sync_files() {
    local engine="$1"
    local base
    base=$(get_sync_files "$engine")
    local extra="src/index.ts CLAUDE.md"
    case "$engine" in
        claude-code|copilot-cli|gemini-cli|qwen-code|codex)
            extra="$extra server/src/index.ts"
            ;;
        adkcode)
            extra="$extra server/api.py"
            ;;
        gocode)
            extra="$extra server/internal/server/server.go"
            ;;
    esac
    echo "$base $extra"
}

# Generate reference file from template with placeholders replaced
generate_reference() {
    local template_file="$1"
    local output_file="$2"
    local project_name="$3"
    local container_prefix="$project_name"
    local domain="${project_name}.${DEFAULT_DOMAIN_SUFFIX}"
    local github_org="$DEFAULT_GITHUB_ORG"

    cp "$template_file" "$output_file"
    sed -i \
        -e "s|{{PROJECT_NAME}}|${project_name}|g" \
        -e "s|{{CONTAINER_PREFIX}}|${container_prefix}|g" \
        -e "s|{{TUNNEL_NAME}}|${project_name}|g" \
        -e "s|{{DOMAIN}}|${domain}|g" \
        -e "s|{{GITHUB_ORG}}|${github_org}|g" \
        "$output_file"
}

# Sync a single project
sync_project() {
    local name="$1"
    local apply="$2"
    local full="${3:-false}"
    local bot_dir="$PROJECTS_DIR/$name/bot-service"

    if [[ ! -d "$bot_dir" ]]; then
        print_error "  Project '$name' not found"
        return 1
    fi

    local engine
    engine=$(detect_engine "$name")

    if [[ "$engine" == "unknown" ]]; then
        print_error "  Cannot detect engine for '$name'"
        return 1
    fi

    local template
    template=$(engine_to_template "$engine")

    if [[ -z "$template" ]]; then
        print_error "  No template mapping for engine '$engine'"
        return 1
    fi

    local template_dir="$TEMPLATES_DIR/$template"
    local sync_files
    if [[ "$full" == "true" ]]; then
        sync_files=$(get_full_sync_files "$engine")
    else
        sync_files=$(get_sync_files "$engine")
    fi

    echo -e "  ${BOLD}$name${NC} ${DIM}($engine)${NC}"

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" RETURN

    local has_diff=false
    local file_count=0
    local diff_count=0
    local applied_count=0

    for file in $sync_files; do
        file_count=$((file_count + 1))
        local template_file="$template_dir/$file"
        local project_file="$bot_dir/$file"

        # Skip if template file doesn't exist
        if [[ ! -f "$template_file" ]]; then
            continue
        fi

        # Generate reference with placeholders replaced
        mkdir -p "$tmpdir/$(dirname "$file")"
        local ref_file="$tmpdir/$file"
        generate_reference "$template_file" "$ref_file" "$name"

        if [[ ! -f "$project_file" ]]; then
            # File exists in template but not in project
            echo -e "    ${YELLOW}+ $file${NC} (new file from template)"
            diff_count=$((diff_count + 1))
            has_diff=true
            if [[ "$apply" == "true" ]]; then
                mkdir -p "$(dirname "$project_file")"
                cp "$ref_file" "$project_file"
                echo -e "      ${GREEN}applied${NC}"
                applied_count=$((applied_count + 1))
            fi
        elif ! diff -q "$project_file" "$ref_file" >/dev/null 2>&1; then
            # Files differ
            echo -e "    ${YELLOW}~ $file${NC}"
            diff_count=$((diff_count + 1))
            has_diff=true

            # Show compact diff (unified, 3 lines context)
            diff -u "$project_file" "$ref_file" \
                --label "project/$name/$file" \
                --label "template/$file" \
                2>/dev/null | head -40 || true

            if [[ "$apply" == "true" ]]; then
                # Backup original
                cp "$project_file" "${project_file}.bak"
                cp "$ref_file" "$project_file"
                echo -e "      ${GREEN}applied${NC} (backup: ${file}.bak)"
                applied_count=$((applied_count + 1))
            fi
            echo ""
        else
            echo -e "    ${GREEN}= $file${NC} ${DIM}(up to date)${NC}"
        fi
    done

    if [[ "$has_diff" == "false" ]]; then
        echo -e "    ${GREEN}All $file_count files up to date${NC}"
    elif [[ "$apply" != "true" ]]; then
        echo -e "    ${DIM}$diff_count file(s) differ. Use --apply to update.${NC}"
    else
        echo -e "    ${GREEN}$applied_count file(s) applied${NC}"
    fi
    echo ""
}

# --- Command: sync ---
cmd_sync() {
    local target="${1:-}"
    local flag="${2:-}"
    local apply=false
    local full=false

    # Parse flags from any position
    for arg in "$@"; do
        case "$arg" in
            --apply) apply=true ;;
            --full) full=true ;;
            --*) ;;
            *) target="$arg" ;;
        esac
    done

    print_header

    if [[ -z "$target" ]]; then
        echo "  Usage:"
        echo ""
        echo "    ./botforge sync <name|all>                  Show diffs (dry-run)"
        echo "    ./botforge sync <name|all> --apply          Apply template updates"
        echo "    ./botforge sync <name|all> --apply --full   Include src/index.ts"
        echo ""
        echo "  Syncs infrastructure files from templates to existing projects."
        echo "  Files synced: Dockerfile, docker-compose.yml, opencode.json, .env.example"
        echo "  With --full:  + src/index.ts, CLAUDE.md, server code (overwrites customizations)"
        echo "  Files NOT synced: AGENTS.md, .env (user data)"
        echo ""
        return
    fi

    local mode_label="DRY RUN"
    if [[ "$apply" == "true" ]]; then
        mode_label="APPLY"
    fi
    if [[ "$full" == "true" ]]; then
        mode_label="$mode_label + FULL"
    fi

    if [[ "$apply" == "true" ]]; then
        echo -e "  ${BOLD}Mode: ${mode_label}${NC} (will update files + create .bak backups)"
    else
        echo -e "  ${BOLD}Mode: ${mode_label}${NC} (showing diffs only)"
    fi
    echo ""

    local projects=()
    if [[ "$target" == "all" ]]; then
        for dir in "$PROJECTS_DIR"/*/; do
            if [[ -d "$dir/bot-service" ]]; then
                projects+=("$(basename "$dir")")
            fi
        done
    else
        projects=("$target")
    fi

    if [[ ${#projects[@]} -eq 0 ]]; then
        echo "  No projects found."
        echo ""
        return
    fi

    for name in "${projects[@]}"; do
        sync_project "$name" "$apply" "$full"
    done

    if [[ "$apply" != "true" ]]; then
        echo -e "  ${DIM}Run with --apply to update files.${NC}"
        echo ""
    fi
}

# --- Command: help ---
cmd_help() {
    print_header
    echo "  Usage:"
    echo ""
    echo "    ./botforge new <project-name>       Create a new project"
    echo "    ./botforge sync <name|all>          Sync project with latest template"
    echo "    ./botforge list                     List all projects"
    echo "    ./botforge deploy <command> [args]  Deploy & manage (shortcut for botforge-deploy)"
    echo "    ./botforge help                     Show this help"
    echo ""
    echo "  Examples:"
    echo ""
    echo "    ./botforge new hr-bot"
    echo "    ./botforge new customer-support"
    echo "    ./botforge new sales-assistant"
    echo ""
    echo "  Engines:"
    echo ""
    echo "    opencode     Multi-model AI (Claude, GPT, Gemini, DeepSeek, Qwen, Groq)"
    echo "    claude-code  Claude only (Agent SDK, simpler, built-in cost control)"
    echo "    gocode       Go + OpenAI-compatible (DeepSeek, GPT, Qwen, Groq, Ollama)"
    echo "    adkcode      Google ADK + Gemini (multi-agent: coder, reviewer, tester)"
    echo "    gemini-cli   Google Gemini CLI (agentic, session support, Google Search)"
    echo "    qwen-code   Alibaba Qwen Code CLI (agentic, free 1K req/day via OAuth)"
    echo "    codex       OpenAI Codex CLI (agentic, ChatGPT login or API key)"
    echo ""
    echo "  Each project generates 2 directories:"
    echo ""
    echo "    projects/<name>/bot-service/     LINE Bot + AI Server + Cloudflare Tunnel"
    echo "    projects/<name>/workspace/       Knowledge base, skills, memory, docs"
    echo ""
}

# --- Main ---
main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        new)
            cmd_new "$@"
            ;;
        sync)
            cmd_sync "$@"
            ;;
        list|ls)
            cmd_list
            ;;
        deploy)
            exec "$SCRIPT_DIR/botforge-deploy" "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            print_error "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
