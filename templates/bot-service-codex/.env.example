# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_OA_URL=https://line.me/ti/p/~your-oa

# Server (Codex CLI) — choose ONE auth method:

# Option 1: ChatGPT login (recommended) — reuse host login, no API key needed
# Run `codex login` on host first, then mount ~/.codex
CODEX_HOME=~/.codex

# Option 2: API key — get from https://platform.openai.com/api-keys
# CODEX_API_KEY=sk-...
# CODEX_HOME=

CODEX_MODEL=o4-mini
CODEX_TIMEOUT_MS=300000
API_PASSWORD=

# Project
PROJECT_DIR=./workspace
PROMPT_TIMEOUT_MS=300000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
