# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_OA_URL=https://line.me/ti/p/~your-oa

# Server (Gemini CLI) — choose ONE auth method:

# Option 1: OAuth (recommended) — reuse host login, no API key needed
# Run `gemini` on host first to login, then mount ~/.gemini
GEMINI_HOME=~/.gemini

# Option 2: API key — get from https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_HOME=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=300000
API_PASSWORD=

# Project
PROJECT_DIR=./workspace
PROMPT_TIMEOUT_MS=300000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
