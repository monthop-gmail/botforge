# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Server (Copilot CLI → GitHub Copilot API)
# Auth: GitHub token or gh CLI OAuth (mounted from host)

# Option 1: GitHub token (PAT with "Copilot Requests" permission)
GITHUB_TOKEN=ghp_...

# Option 2: gh CLI OAuth (mount host ~/.config/gh)
# GH_CONFIG_DIR=~/.config/gh
# GITHUB_TOKEN=

# Option 3: Login inside container
# docker exec -it <container> copilot /login

API_PASSWORD=
COPILOT_MODEL=claude-sonnet-4.5
COPILOT_MAX_TURNS=10
COPILOT_TIMEOUT_MS=300000

# Project
PROJECT_DIR=./workspace
PROMPT_TIMEOUT_MS=300000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
