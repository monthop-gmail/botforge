# LINE Credentials
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_OA_URL=https://line.me/ti/p/~your-oa

# Google AI — choose ONE auth method:

# Option 1: API key (simple) — get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Option 2: Vertex AI + ADC (no API key needed)
# Run `gcloud auth application-default login` on host first
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model configuration (optional)
# Smart model — used by orchestrator and reviewer
ADKCODE_MODEL_SMART=gemini-2.5-flash
# Fast model — used by coder and tester
ADKCODE_MODEL_FAST=gemini-2.0-flash

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Server (optional)
API_PASSWORD=
PORT=3000
PROMPT_TIMEOUT_MS=120000
