#!/usr/bin/env bash
set -euo pipefail

# ─── Botforge Models — Fetch latest model lists from AI providers ───

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OUTPUT_DIR="$SCRIPT_DIR/models"
TIMESTAMP=$(date +%Y-%m-%d)

# Colors
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; DIM='\033[2m'; BOLD='\033[1m'; RESET='\033[0m'

header() { echo -e "${CYAN}${BOLD}Botforge Models — AI Provider Model List${RESET}"; echo -e "${CYAN}─────────────────────────────────────────${RESET}"; echo; }

# ─── Load API keys from any .env that has them ───
load_keys() {
  local env_files=()
  # Check for a dedicated keys file first
  [[ -f "$SCRIPT_DIR/.botforge-models.env" ]] && env_files+=("$SCRIPT_DIR/.botforge-models.env")
  # Then check all project .env files
  for f in "$SCRIPT_DIR"/projects/*/bot-service/.env; do
    [[ -f "$f" ]] && env_files+=("$f")
  done

  for f in "${env_files[@]}"; do
    while IFS='=' read -r key val; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      key=$(echo "$key" | xargs)
      val=$(echo "$val" | xargs)
      # Only set if not already set and value is not a placeholder
      if [[ -z "${!key:-}" && -n "$val" && "$val" != your-* && "$val" != sk-... && "$val" != AIza... && "$val" != gsk_... && "$val" != changeme ]]; then
        export "$key=$val"
      fi
    done < "$f"
  done
}

# ─── Provider fetch functions ───

fetch_anthropic() {
  local key="${ANTHROPIC_API_KEY:-}"
  local auth_header=""
  if [[ -n "$key" ]]; then
    auth_header="x-api-key: $key"
  else
    # Fallback: read OAuth token from ~/.claude/.credentials.json
    local cred_file="$HOME/.claude/.credentials.json"
    if [[ -f "$cred_file" ]]; then
      local token
      token=$(jq -r '.claudeAiOauth.accessToken // empty' "$cred_file" 2>/dev/null)
      if [[ -n "$token" ]]; then
        auth_header="Authorization: Bearer $token"
        echo -e "  ${DIM}(using OAuth from ~/.claude/.credentials.json)${RESET}"
      fi
    fi
  fi
  [[ -z "$auth_header" ]] && echo -e "  ${YELLOW}skip${RESET} (no ANTHROPIC_API_KEY)" && return 0
  local out
  out=$(curl -s "https://api.anthropic.com/v1/models?limit=100" \
    -H "anthropic-version: 2023-06-01" \
    -H "$auth_header" 2>/dev/null)
  if echo "$out" | jq -e '.error' &>/dev/null; then
    if [[ "$auth_header" == Authorization* ]]; then
      echo -e "  ${RED}error${RESET} (OAuth not supported on /v1/models, use ANTHROPIC_API_KEY instead)"
    else
      echo -e "  ${RED}error${RESET} (API call failed)"
    fi
    return 0
  fi
  echo "$out" | jq -r '.data[] | .id + "\t" + (.created_at | todate | split("T")[0])' | sort > "$OUTPUT_DIR/anthropic.txt"
  local count=$(wc -l < "$OUTPUT_DIR/anthropic.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/anthropic.txt)${RESET}"
}

fetch_openai() {
  local key="${OPENAI_API_KEY:-}"
  [[ -z "$key" ]] && echo -e "  ${YELLOW}skip${RESET} (no OPENAI_API_KEY)" && return 0
  local out
  out=$(curl -sf "https://api.openai.com/v1/models" \
    -H "Authorization: Bearer $key" 2>/dev/null) || { echo -e "  ${RED}error${RESET} (API call failed)"; return 0; }
  echo "$out" | jq -r '.data[] | .id + "\t" + (.created | todate | split("T")[0])' | sort > "$OUTPUT_DIR/openai.txt"
  local count=$(wc -l < "$OUTPUT_DIR/openai.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/openai.txt)${RESET}"
}

fetch_google() {
  local key="${GOOGLE_API_KEY:-}"
  [[ -z "$key" ]] && echo -e "  ${YELLOW}skip${RESET} (no GOOGLE_API_KEY)" && return 0
  local out
  out=$(curl -sf "https://generativelanguage.googleapis.com/v1beta/models?pageSize=1000&key=$key" 2>/dev/null) || { echo -e "  ${RED}error${RESET} (API call failed)"; return 0; }
  echo "$out" | jq -r '.models[] | (.name | sub("^models/";""))' | sort > "$OUTPUT_DIR/google.txt"
  local count=$(wc -l < "$OUTPUT_DIR/google.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/google.txt)${RESET}"
}

fetch_deepseek() {
  local key="${DEEPSEEK_API_KEY:-}"
  [[ -z "$key" ]] && echo -e "  ${YELLOW}skip${RESET} (no DEEPSEEK_API_KEY)" && return 0
  local out
  out=$(curl -sf "https://api.deepseek.com/v1/models" \
    -H "Authorization: Bearer $key" 2>/dev/null) || { echo -e "  ${RED}error${RESET} (API call failed)"; return 0; }
  echo "$out" | jq -r '.data[] | if .created then .id + "\t" + (.created | todate | split("T")[0]) else .id end' | sort > "$OUTPUT_DIR/deepseek.txt"
  local count=$(wc -l < "$OUTPUT_DIR/deepseek.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/deepseek.txt)${RESET}"
}

fetch_qwen() {
  local key="${QWEN_API_KEY:-}"
  [[ -z "$key" ]] && echo -e "  ${YELLOW}skip${RESET} (no QWEN_API_KEY)" && return 0
  local out
  out=$(curl -sf "https://dashscope-intl.aliyuncs.com/compatible-mode/v1/models" \
    -H "Authorization: Bearer $key" 2>/dev/null) || { echo -e "  ${RED}error${RESET} (API call failed)"; return 0; }
  echo "$out" | jq -r '.data[] | if .created then .id + "\t" + (.created | todate | split("T")[0]) else .id end' | sort > "$OUTPUT_DIR/qwen.txt"
  local count=$(wc -l < "$OUTPUT_DIR/qwen.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/qwen.txt)${RESET}"
}

fetch_groq() {
  local key="${GROQ_API_KEY:-}"
  [[ -z "$key" ]] && echo -e "  ${YELLOW}skip${RESET} (no GROQ_API_KEY)" && return 0
  local out
  out=$(curl -sf "https://api.groq.com/openai/v1/models" \
    -H "Authorization: Bearer $key" 2>/dev/null) || { echo -e "  ${RED}error${RESET} (API call failed)"; return 0; }
  echo "$out" | jq -r '.data[] | if .created then .id + "\t" + (.created | todate | split("T")[0]) else .id end' | sort > "$OUTPUT_DIR/groq.txt"
  local count=$(wc -l < "$OUTPUT_DIR/groq.txt")
  echo -e "  ${GREEN}ok${RESET} ${DIM}($count models → models/groq.txt)${RESET}"
}

# ─── Main ───

PROVIDERS=(anthropic openai google deepseek qwen groq)

usage() {
  echo -e "${CYAN}${BOLD}Botforge Models — AI Provider Model List${RESET}"
  echo
  echo "Usage: ./botforge-models [provider...]"
  echo
  echo "Providers: ${PROVIDERS[*]}"
  echo
  echo "Examples:"
  echo "  ./botforge-models              # Fetch all providers"
  echo "  ./botforge-models groq google  # Fetch specific providers"
  echo "  ./botforge-models --list       # Show cached model lists"
  echo
  echo "API keys are loaded from project .env files or .botforge-models.env"
  echo "Output: models/<provider>.txt"
}

list_cached() {
  header
  if [[ ! -d "$OUTPUT_DIR" ]] || ! ls "$OUTPUT_DIR"/*.txt &>/dev/null; then
    echo -e "  ${DIM}No cached models. Run ./botforge-models to fetch.${RESET}"
    return
  fi
  for f in "$OUTPUT_DIR"/*.txt; do
    local name=$(basename "$f" .txt)
    local count=$(wc -l < "$f")
    local date=$(date -r "$f" +%Y-%m-%d 2>/dev/null || stat -c %y "$f" 2>/dev/null | cut -d' ' -f1)
    echo -e "  ${BOLD}$name${RESET} ${DIM}($count models, updated $date)${RESET}"
  done
  echo
  echo -e "  ${DIM}Files in: $OUTPUT_DIR/${RESET}"
}

main() {
  case "${1:-}" in
    -h|--help|help) usage; exit 0 ;;
    --list|list|ls) list_cached; exit 0 ;;
  esac

  header
  load_keys
  mkdir -p "$OUTPUT_DIR"

  local targets=("${@}")
  [[ ${#targets[@]} -eq 0 ]] && targets=("${PROVIDERS[@]}")

  for provider in "${targets[@]}"; do
    echo -e "  ${BOLD}$provider${RESET}"
    case "$provider" in
      anthropic) fetch_anthropic ;;
      openai)    fetch_openai ;;
      google)    fetch_google ;;
      deepseek)  fetch_deepseek ;;
      qwen)      fetch_qwen ;;
      groq)      fetch_groq ;;
      *) echo -e "  ${RED}unknown provider${RESET}: $provider" ;;
    esac
  done

  echo
  echo -e "  ${DIM}Updated: $TIMESTAMP${RESET}"
  echo -e "  ${DIM}Output:  $OUTPUT_DIR/${RESET}"
}

main "$@"
