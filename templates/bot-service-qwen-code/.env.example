# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Server (Qwen Code) — choose ONE auth method:

# Option 1: OAuth (recommended) — reuse host login, no API key needed
# Run `qwen` on host first to login, then mount ~/.qwen
QWEN_HOME=~/.qwen

# Option 2: API key — get from https://modelstudio.console.alibabacloud.com
# DASHSCOPE_API_KEY=sk-...
# QWEN_HOME=

QWEN_MODEL=qwen3-coder-plus
QWEN_TIMEOUT_MS=300000
API_PASSWORD=

# Project
PROJECT_DIR=./workspace
PROMPT_TIMEOUT_MS=300000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
