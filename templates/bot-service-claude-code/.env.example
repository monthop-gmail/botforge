# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Server (Claude Code → Anthropic API)
# Choose ONE auth method:

# Option 1: API key
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OAuth (no API key needed)
# Mount host ~/.claude or login inside container: docker exec -it <container> claude login
# ANTHROPIC_API_KEY=
# CLAUDE_HOME=~/.claude

API_PASSWORD=
CLAUDE_MODEL=sonnet
CLAUDE_MAX_TURNS=10
CLAUDE_MAX_BUDGET_USD=1.00

# Project
PROJECT_DIR=./workspace
PROMPT_TIMEOUT_MS=300000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
